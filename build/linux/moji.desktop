[Desktop Entry]
Name=Moji
Exec=AppRun --no-sandbox %U
Terminal=false
Type=Application
Icon=moji
StartupWMClass=moji
Keywords=Markdown;Editor;Viewer;Documents;Notes;
Comment=Moji is a desktop app for opening, reading, editing, and exporting Markdown files with split preview/editing, outline navigation, localized UI, and PDF, HTML, and PNG export.
MimeType=text/markdown;
Categories=Office;
